+<file path="core/scenario_analyzer.py">
+class ScenarioAnalyzer:
+    """
+    Базовый анализ сценария
+    Машина приехала -> появился человек -> человек исчез -> машина исчезла
+    """
+    def __init__(self, max_wait_time=300, max_person_time=600, person_without_car_delay=10.0):
+        """
+        :param max_wait_time: максимальное время ожидания человека в машине (сек)
+        :param max_person_time: максимальное время человека в кадре (сек)
+        """
+        self.person_without_car_alerted = False
+        self.person_without_car_start_time = None
+        self.person_without_car_delay = person_without_car_delay
+        self.max_wait_time = max_wait_time
+        self.max_person_time = max_person_time
+
+        # Контроль состояний
+        self.car_present = False
+        self.person_present = False
+        self.car_appearance_time = None
+        self.person_appearance_time = None
+
+        # Флаги для предотвращения дублирования тревог
+        self.car_abandoned_alerted = False
+        self.person_too_long_alerted = False
+
+        self.alerts = []
+
+    def update(self, objects, current_time):
+        """
+        :param objects:
+        :param current_time:
+        :return: список тревог (если есть)
+        """
+        has_car = any(obj.get('class_name') == 'car' for obj in objects)
+        has_person = any(obj.get('class_name') == 'person' for obj in objects)
+
+        # человек без машины
+        if has_person and not has_car:
+            if self.person_without_car_start_time is None:
+                self.person_without_car_start_time = current_time
+                self.person_without_car_alerted = False
+            else:
+                time_without_car = current_time - self.person_without_car_start_time
+                if time_without_car >= self.person_without_car_delay and not self.person_without_car_alerted:
+                    self._add_alert("Человек появился без автомобиля", current_time)
+                    self.person_without_car_alerted = True
+        else:
+            self.person_without_car_start_time = None
+            self.person_without_car_alerted = False
+
+        # контроль состояния автомобиля
+        if has_car and not self.car_present:
+            self.car_present = True
+            self.car_appearance_time = current_time
+            self.car_abandoned_alerted = False
+
+        if not has_car and self.car_present:
+            self.car_present = False
+            self.car_appearance_time = None
+            self.car_abandoned_alerted = False
+
+        # контроль состояния человека
+        if has_person and not self.person_present:
+            self.person_present = True
+            self.person_appearance_time = current_time
+            self.person_too_long_alerted = False
+
+        if not has_person and self.person_present:
+            self.person_present = False
+            self.person_appearance_time = None
+            self.person_too_long_alerted = False
+
+        # машина стоит слишком долго и рядом нет людей
+        if self.car_present and not self.person_present and self.car_appearance_time:
+            wait_time = current_time - self.car_appearance_time
+            if wait_time > self.max_wait_time and not self.car_abandoned_alerted:
+                self._add_alert(f"Машина стоит без человека {int(wait_time)}с", current_time)
+                self.car_abandoned_alerted = True
+
+        # человек слишком долго находится на АЗС
+        if self.person_present and self.person_appearance_time:
+            person_time = current_time - self.person_appearance_time
+            if person_time > self.max_person_time and not self.person_too_long_alerted:
+                self._add_alert(f"Человек в кадре {int(person_time)}с (возможно, не заправляется)", current_time)
+                self.person_too_long_alerted = True
+
+        return self.get_alerts()
+
+    def _add_alert(self, message, current_time):
+        """
+        Создаёт тревогу
+        :param message:
+        :param current_time:
+        """
+        self.alerts.append({
+            'type': 'scenario_violation',
+            'time': current_time,
+            'message': message
+        })
+
+    def get_alerts(self):
+        alerts = self.alerts.copy()
+        self.alerts.clear()
+        return alerts
+
+    def reset(self):
+        """Полный сброс состояния"""
+        self.car_present = False
+        self.person_present = False
+        self.car_appearance_time = None
+        self.person_appearance_time = None
+        self.car_abandoned_alerted = False
+        self.person_too_long_alerted = False
+        self.alerts.clear()
