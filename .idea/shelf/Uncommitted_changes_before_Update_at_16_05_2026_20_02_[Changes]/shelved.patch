+from PyQt6.QtWidgets import QWidget, QGridLayout, QFrame
+from PyQt6.QtCore import Qt
+from ui.video_widget import VideoWidget
+
+
+class ImageStitcher(QWidget):
+    """
+    Склеивает видео с нескольких источников в сетку
+    """
+
+    def __init__(self, parent=None):
+        super().__init__(parent)
+        self.layout = QGridLayout()
+        self.layout.setSpacing(2)
+        self.layout.setContentsMargins(0, 0, 0, 0)
+        self.setLayout(self.layout)
+
+        self.video_widgets = {}
+        self.grid_size = (2, 2)  # по умолчанию 2x2
+
+    def set_sources(self, sources):
+        """
+        получает список источников
+        """
+        count = len(sources)
+
+        # Определяем размер сетки(ограничение 16 источников)
+        if count <= 1:
+            self.grid_size = (1, 1)
+        elif count <= 4:
+            self.grid_size = (2, 2)
+        elif count <= 9:
+            self.grid_size = (3, 3)
+        else:
+            self.grid_size = (4, 4)
+
+        # Очищаем layout
+        self._clear_layout()
+
+        # Добавляем виджеты для каждого источника
+        for i, source in enumerate(sources):
+            row = i // self.grid_size[1]
+            col = i % self.grid_size[1]
+
+            if source['id'] not in self.video_widgets:
+                self.video_widgets[source['id']] = VideoWidget()
+
+            container = QFrame()
+            container.setFrameShape(QFrame.Shape.Box)
+            container.setStyleSheet("border: 1px solid #cccccc;")
+
+            layout_inner = QGridLayout()
+            layout_inner.setContentsMargins(0, 0, 0, 0)
+            layout_inner.addWidget(self.video_widgets[source['id']])
+            container.setLayout(layout_inner)
+
+            self.layout.addWidget(container, row, col)
+
+        # Заполняем пустые ячейки чёрным
+        total_cells = self.grid_size[0] * self.grid_size[1]
+        for i in range(len(sources), total_cells):
+            empty = QFrame()
+            empty.setStyleSheet("background-color: black;")
+            row = i // self.grid_size[1]
+            col = i % self.grid_size[1]
+            self.layout.addWidget(empty, row, col)
+
+    def _clear_layout(self):
+        """Очистка layout"""
+        while self.layout.count():
+            item = self.layout.takeAt(0)
+            if item.widget():
+                item.widget().deleteLater()
+
+    def update_frame(self, source_id, frame, active_zones, objects):
+        """Обновление кадра для конкретного источника"""
+        if source_id in self.video_widgets:
+            self.video_widgets[source_id].set_frame(frame, active_zones, objects)
