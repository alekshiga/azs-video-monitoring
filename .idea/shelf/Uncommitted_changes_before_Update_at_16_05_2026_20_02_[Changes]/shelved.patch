+            "Подтверждение",
+            f"Удалить камеру '{camera_name}'?",
+            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No
+        )
+
+        if reply == QMessageBox.StandardButton.Yes:
+            zones_file = self.source_manager.get_zones_file(source_id)
+            if zones_file and os.path.exists(zones_file):
+                os.remove(zones_file)
+                self._add_log(f"Удалён файл зон камеры")
+
+            self.source_manager.remove_source(source_id)
+            self._refresh_source_list()
+            self._add_log(f"Удалена камера: {camera_name}")
+
+            if self.source_combo.count() == 0:
+                self.source_manager.active_source_id = None
+                self.single_video_widget.zones.clear()
+                self.single_video_widget.zone_names.clear()
+                self.single_video_widget.update()
+
+    def _on_all_frames_ready(self, all_frames):
+        """Приём кадров от всех источников"""
+        if self.current_mode == "multi":
+            # Собираем список активных источников
+            sources_list = []
+            for f in all_frames:
+                if f['frame'] is not None:
+                    sources_list.append({'id': f['id']})
+
+            if sources_list:
+                self.image_stitcher.set_sources(sources_list)
+
+            for frame_data in all_frames:
+                if frame_data['frame'] is not None:
+                    self.image_stitcher.update_frame(
+                        frame_data['id'],
+                        frame_data['frame'],
+                        frame_data['active_zones'],
+                        frame_data['objects']
+                    )
+        elif self.current_mode == "single" and self.current_source_id:
+            # Показываем только выбранную камеру
+            for frame_data in all_frames:
+                if frame_data['id'] == self.current_source_id and frame_data['frame'] is not None:
+                    self.single_video_widget.set_frame(
+                        frame_data['frame'],
+                        frame_data['active_zones'],
+                        frame_data['objects']
+                    )
+                    break
+
+    def _load_zones(self):
+        """Загрузка зон из файла для текущей камеры"""
+        if self.current_mode != "single":
+            self._add_log("Переключитесь в режим 'Одна камера' для работы с зонами")
+            return
+
+        source_id = self.current_source_id
+        if not source_id:
+            self._add_log("Сначала выберите камеру")
+            return
+
+        filepath, _ = QFileDialog.getOpenFileName(
+            self, "Выберите файл зон", f"zones_cam_{source_id}.json", "JSON Files (*.json)"
+        )
+        if not filepath:
+            return
+
+        zone_manager = self.video_thread.get_zone_manager(source_id)
+        if not zone_manager:
+            self._add_log("Ошибка: менеджер зон не найден")
+            return
+
+        if zone_manager.load_from_file(filepath):
+            self.single_video_widget.set_zones(zone_manager.zones, zone_manager.zone_names)
+            self.video_thread.update_zones(zone_manager.zones, source_id)
+            self._update_zones_count()
+            self._add_log(f"Загружены зоны из {filepath}")
+        else:
+            self._add_log(f"Ошибка загрузки зон из {filepath}")
+
+    def _save_zones(self):
+        """Сохранение зон в файл"""
+        if self.current_mode != "single":
+            self._add_log("Переключитесь в режим 'Одна камера' для работы с зонами")
+            return
+
+        source_id = self.current_source_id
+        if not source_id:
+            self._add_log("Сначала выберите камеру")
+            return
+
+        zones = self.single_video_widget.zones
+        zone_names = self.single_video_widget.zone_names
+
+        if not zones:
+            self._add_log("Нет зон для сохранения")
+            return
+
+        zone_manager = self.video_thread.get_zone_manager(source_id)
+        if not zone_manager:
+            self._add_log("Ошибка: менеджер зон не найден")
+            return
+
+        zone_manager.set_zones(zones, zone_names)
+        zone_manager.camera_id = source_id
+
+        zones_file = self.source_manager.get_zones_file(source_id)
+        if zone_manager.save_to_file(zones_file):
+            self._add_log(f"Зоны сохранены (камера {source_id})")
+        else:
+            self._add_log(f"Ошибка сохранения зон")
+
+    def _clear_zones(self):
+        """Очистка зон для выбранной камеры"""
+        if self.current_mode != "single":
+            self._add_log("Переключитесь в режим 'Одна камера' для работы с зонами")
+            return
+
+        source_id = self.current_source_id
+        if not source_id:
+            self._add_log("Сначала выберите камеру")
+            return
+
+        self.single_video_widget.zones.clear()
+        self.single_video_widget.zone_names.clear()
+        self.single_video_widget.update()
+
+        zone_manager = self.video_thread.get_zone_manager(source_id)
+        if zone_manager:
+            zone_manager.clear_zones()
+
+        self.video_thread.update_zones([], source_id)
+        self._update_zones_count()
+        self._add_log("Зоны очищены")
+
+    def _on_zones_updated(self, zones):
+        if self.current_mode != "single":
+            return
+
+        source_id = self.current_source_id
+        if source_id:
+            self.video_thread.update_zones(zones, source_id)
+            self._update_zones_count()
+
+    def _clear_log(self):
+        self.log_widget.clear()
+
+    def _update_zones_count(self):
+        """Обновляем счётчик зон"""
+        count = len(self.single_video_widget.zones)
+        self.zones_count_label.setText(f"Зон: {count}")
+
+    def _add_log(self, text):
+        if hasattr(self, '_last_log_time') and time.time() - self._last_log_time < 0.05:
+            return
+        self._last_log_time = time.time()
+
+        timestamp = datetime.now().strftime("%H:%M:%S")
+        self.log_widget.append(f"[{timestamp}] {text}")
+        scrollbar = self.log_widget.verticalScrollBar()
+        if scrollbar:
+            scrollbar.setValue(scrollbar.maximum())
+
+    def _toggle_draw_rectangles(self, state):
+        draw = state == 2  # Qt.Checked
+        self.video_thread.draw_rectangles = draw
+        self.single_video_widget.draw_rectangles = draw
+        for widget in self.image_stitcher.video_widgets.values():
+            widget.draw_rectangles = draw
+        self._add_log(f"Отрисовка рамок: {'включена' if draw else 'выключена'}")
+
+    def on_zone_alert(self, zone_index, frame, source_id):
+        """Обработчик тревоги в зоне наблюдения"""
+        zone_name = None
+        if source_id == self.current_source_id:
+            if 0 <= zone_index < len(self.single_video_widget.zone_names):
+                zone_name = self.single_video_widget.zone_names[zone_index]
+        else:
+            # Для режима всех камер
+            if source_id in self.image_stitcher.video_widgets:
+                widget = self.image_stitcher.video_widgets[source_id]
+                if 0 <= zone_index < len(widget.zone_names):
+                    zone_name = widget.zone_names[zone_index]
+
+        source = self.source_manager.get_source(source_id)
+        if source and zone_name:
+            full_name = f"{source.name} - {zone_name}"
+        elif source:
+            full_name = f"{source.name} - зона {zone_index}"
+        else:
+            full_name = f"Камера {source_id} - зона {zone_index}"
+
+        self.telegram.send_alert(zone_index, full_name, frame)
+
+    def closeEvent(self, event):
